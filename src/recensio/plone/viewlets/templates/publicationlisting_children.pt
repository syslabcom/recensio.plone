<div class="publicationlisting-children"
     tal:define="
       issues view/issues;
       reviews view/reviews;
     "
     tal:attributes="
       id view/panel_id;
     "
     i18n:domain="recensio"
>
  <section class="publicationlisting-panel-section"
           tal:condition="reviews"
  >
    <h3 class="publicationlisting-panel-section__title"
        i18n:translate="label_publication_reviews"
    >Reviews</h3>

    <ul class="publicationlisting-review-list">
      <li class="publicationlisting-review-list__item"
          tal:repeat="review reviews"
      >
        <a class="publicationlisting-review-card"
           href=""
           tal:attributes="
             href review/url;
           "
        >
          <span class="publicationlisting-review-card__authors"
                tal:condition="review/authors"
                tal:content="review/authors"
          >Doe, Jane</span>
          <span class="publicationlisting-review-card__title"
                tal:content="review/title"
          >Review title</span>
          <span class="publicationlisting-review-card__date"
                tal:condition="review/effective_date"
                tal:content="review/effective_date"
          >2026-03-29</span>
        </a>
      </li>
    </ul>
  </section>

  <section class="publicationlisting-panel-section"
           tal:condition="issues"
  >
    <h3 class="publicationlisting-panel-section__title"
        i18n:translate="label_publication_issues"
    >Issues</h3>

    <div class="publicationlisting-stack publicationlisting-stack--nested">
      <tal:issues repeat="issue issues">
        <details class="publicationlisting-card publicationlisting-card--issue"
                 data-error-label="Could not load contents."
                 data-loading-label="Loading contents…"
                 tal:condition="issue/has_children"
                 tal:attributes="
                   data-publicationlisting-load-url issue/load_url;
                 "
                 i18n:attributes="data-error-label description_publicationlisting_loading_failed; data-loading-label label_publicationlisting_loading"
        >
          <summary class="publicationlisting-card__summary">
            <span class="publicationlisting-card__summary-copy">
              <span class="publicationlisting-card__eyebrow"
                    i18n:translate="label_publication_issue"
              >Issue</span>
              <span class="publicationlisting-card__title"
                    tal:content="issue/title"
              >Issue 01</span>
            </span>
            <span class="publicationlisting-card__summary-actions">
              <span class="publicationlisting-card__hint"
                    i18n:translate="label_publication_show_reviews"
              >Show reviews</span>
              <span class="publicationlisting-card__chevron"
                    aria-hidden="true"
              ></span>
            </span>
          </summary>

          <div class="publicationlisting-card__meta">
            <div class="publicationlisting-card__badges">
              <span class="publicationlisting-badge">
                <strong tal:content="issue/review_count">0</strong>
                <span i18n:translate="label_publication_reviews">Reviews</span>
              </span>
            </div>

            <div class="publicationlisting-card__downloads"
                 tal:condition="issue/pdf | nothing"
            >
              <a class="publicationlisting-download"
                 href=""
                 tal:attributes="
                   href string:${issue/pdf}/@@download/file;
                 "
              >
                <span i18n:translate="label_download_complete_pdf">download Gesamt-pdf</span>
              </a>
              <span class="publicationlisting-download__meta discreet">
                PDF,
                <tal:size content="issue/pdfsize">?</tal:size>
              </span>
            </div>
          </div>

          <div class="publicationlisting-card__panel"
               tal:attributes="
                 id issue/panel_id;
               "
          >
            <a class="pat-inject publicationlisting-panel__loader"
               href="#"
               tal:attributes="
                 href string:${issue/load_url}#${issue/panel_id};
                 data-pat-inject python:view.inject_options(issue['panel_id']);
               "
            >
              <span i18n:translate="label_publicationlisting_loading">Loading contents&hellip;</span>
            </a>
          </div>
        </details>

        <article class="publicationlisting-card publicationlisting-card--issue publicationlisting-card--static"
                 tal:condition="not:issue/has_children"
        >
          <header class="publicationlisting-card__summary publicationlisting-card__summary--static">
            <span class="publicationlisting-card__summary-copy">
              <span class="publicationlisting-card__eyebrow"
                    i18n:translate="label_publication_issue"
              >Issue</span>
              <span class="publicationlisting-card__title"
                    tal:content="issue/title"
              >Issue 01</span>
            </span>
          </header>

          <div class="publicationlisting-card__meta">
            <div class="publicationlisting-card__badges">
              <span class="publicationlisting-badge">
                <strong tal:content="issue/review_count">0</strong>
                <span i18n:translate="label_publication_reviews">Reviews</span>
              </span>
            </div>

            <div class="publicationlisting-card__downloads"
                 tal:condition="issue/pdf | nothing"
            >
              <a class="publicationlisting-download"
                 href=""
                 tal:attributes="
                   href string:${issue/pdf}/@@download/file;
                 "
              >
                <span i18n:translate="label_download_complete_pdf">download Gesamt-pdf</span>
              </a>
              <span class="publicationlisting-download__meta discreet">
                PDF,
                <tal:size content="issue/pdfsize">?</tal:size>
              </span>
            </div>
          </div>
        </article>
      </tal:issues>
    </div>
  </section>

  <p class="publicationlisting-panel__empty"
     tal:condition="python:not reviews and not issues"
     i18n:translate="description_publicationlisting_no_contents"
  >No reviews are available yet.</p>
</div>

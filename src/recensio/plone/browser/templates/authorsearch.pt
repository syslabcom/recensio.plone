<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      lang="en"
      metal:use-macro="context/main_template/macros/master"
      xml:lang="en"
      i18n:domain="recensio"
>

  <head>
    <metal:block fill-slot="top_slot"
                 tal:define="
                   dummy python:request.set('disable_border',1);
                   disable_column_one python:request.set('disable_plone.leftcolumn',1);
                   disable_column_two python:request.set('disable_plone.rightcolumn',1);
                 "
    />
    <metal:javascript_head fill-slot="javascript_head_slot">
      <script src="++resource++recensio.theme.javascript/authorsearch.js"
              type="text/javascript"
      ></script>
    </metal:javascript_head>
  </head>
  <body>

    <metal:main fill-slot="main"
                tal:define="
                  jump_links view/author_jump_links;
                  panels view/panels;
                  selected_letter view/selected_letter;
                  use_navigation_root view/use_navigation_root;
                "
    >
      <div class="publications-directory authorsearch-directory"
           id="content-core"
           data-authorsearch-root
           data-error-label="Could not load contents."
           data-loading-label="Loading contents…"
           tal:attributes="
             data-authorsearch-selected-letter selected_letter;
           "
           i18n:attributes="data-loading-label label_publicationlisting_loading;
                            data-error-label description_publicationlisting_loading_failed"
      >
        <header class="publications-hero authorsearch-hero">
          <h1 class="documentFirstHeading"
              i18n:translate=""
          >Autorensuche</h1>
          <p class="publications-intro authorsearch-intro"
             i18n:translate="description_authorsearch_1"
          >
            Sie finden hier die Autorinnen und Autoren von auf
            <span tal:replace="view/portal_title"
                  i18n:name="portal_title"
            >recensio.net</span>
            publizierten Rezensionen
            <span tal:omit-tag=""
                  i18n:name="and_comments"
            ></span>
            sowie die Autoren von hier rezensierten Werken.
          </p>
          <p class="publications-intro authorsearch-intro authorsearch-intro--secondary"
             i18n:translate="description_authorsearch_2"
          >
            Mit einem Klick auf den Autornamen erhalten Sie alle von einem Autor
            publizierten Texte.
          </p>
        </header>

        <form class="search-form search-form-modern authorsearch-search"
              method="get"
              tal:attributes="
                action view/authorsearch_url;
              "
        >
          <div class="search-form-wrapper">
            <label class="sr-only"
                   for="author-search-text"
                   i18n:translate="authorsearch_placeholder"
            >Search Author Index</label>
            <div class="search-input-wrapper">
              <input class="search-input"
                     id="author-search-text"
                     name="authors"
                     placeholder="authorsearch_placeholder"
                     type="text"
                     tal:attributes="
                       value request/authors|nothing;
                     "
                     i18n:attributes="placeholder"
              />
              <input name="use_navigation_root:boolean"
                     type="hidden"
                     value="True"
                     tal:attributes="
                       value python:'True' if use_navigation_root else 'False';
                     "
              />
              <button class="search-button"
                      aria-label="Search"
                      name="search"
                      type="submit"
                      value="Search"
                      i18n:attributes="aria-label label_search"
              >
                <svg xmlns="http://www.w3.org/2000/svg"
                     class="search-icon"
                     aria-hidden="true"
                     viewbox="0 0 24 24"
                >
                  <circle cx="10"
                          cy="10"
                          fill="none"
                          r="6"
                          stroke="currentColor"
                          stroke-width="2"
                  ></circle>
                  <path d="m14.5 14.5 5.5 5.5"
                        stroke="currentColor"
                        stroke-linecap="round"
                        stroke-width="2"
                  ></path>
                </svg>
              </button>
            </div>
          </div>
        </form>

        <div class="authorsearch-summary"
             tal:condition="view/total_authors"
        >
          <p class="authorsearch-summary__count"
             i18n:translate="batch_x_authors_matching_your_criteria"
          >
            <span class="authorsearch-summary__count-badge"
                  tal:content="view/total_authors"
                  i18n:name="number"
            >0</span>
            authors matching your criteria
          </p>
        </div>

        <nav class="publications-jumpnav authorsearch-jumpnav"
             aria-label="Browse authors by initial"
             tal:condition="view/total_authors"
             i18n:attributes="aria-label label_authorsearch_browse_initial"
        >
          <span class="publications-jumpnav__label"
                i18n:translate="label_authorsearch_browse_initial"
          >Browse A&ndash;Z</span>
          <ul class="publications-jumpnav__list"
              role="tablist"
          >
            <tal:letters repeat="link jump_links">
              <li class="publications-jumpnav__item authorsearch-jumpnav__item"
                  tal:attributes="
                    class python:'publications-jumpnav__item authorsearch-jumpnav__item ' + ('is-current' if link['current'] else ('is-active' if link['enabled'] else 'is-disabled'));
                  "
              >
                <a class="publications-jumpnav__link"
                   href="#"
                   role="tab"
                   data-authorsearch-tab
                   tal:condition="link/enabled"
                   tal:content="link/label"
                   tal:attributes="
                     id link/tab_id;
                     href link/href;
                     aria-controls link/panel_id;
                     aria-selected python:'true' if link['current'] else 'false';
                     data-authorsearch-letter link/label;
                     tabindex python:'0' if link['current'] else '-1';
                   "
                >A</a>
                <span class="publications-jumpnav__link"
                      tal:condition="not:link/enabled"
                      tal:content="link/label"
                >A</span>
              </li>
            </tal:letters>
          </ul>
        </nav>

        <div class="publications-empty authorsearch-empty alert alert-info"
             tal:condition="not: view/total_authors"
             i18n:translate="label_no_authors_found"
        >No authors matching your criteria were found.</div>

        <div class="authorsearch-panels"
             data-authorsearch-panels
             tal:condition="panels"
        >
          <tal:panels repeat="panel panels">
            <section class="publication-section authorsearch-panel"
                     role="tabpanel"
                     data-authorsearch-panel
                     tal:attributes="
                       id panel/panel_id;
                       aria-labelledby panel/tab_id;
                       data-authorsearch-initial-url panel/initial_url | nothing;
                       data-authorsearch-letter panel/letter;
                       data-authorsearch-loaded python:'true' if panel['loaded'] else 'false';
                       data-authorsearch-next-url panel/next_url | nothing;
                       hidden python:None if panel['current'] else 'hidden';
                     "
            >
              <div class="publication-section__header">
                <h2 class="publication-section__title"
                    tal:content="panel/letter"
                >A</h2>
                <span class="publication-section__count"
                      tal:content="panel/count"
                >0</span>
              </div>

              <div class="authorsearch-grid"
                   data-authorsearch-results
              >
                <a class="authorsearch-card"
                   tal:repeat="brain panel/authors"
                   tal:attributes="
                     href python:view.author_results_url(brain.UID);
                   "
                >
                  <span class="authorsearch-card__marker"
                        aria-hidden="true"
                  >
                    <span class="authorsearch-card__initial"
                          tal:content="panel/letter"
                    >A</span>
                  </span>
                  <span class="authorsearch-card__body">
                    <span class="authorsearch-card__title"
                          tal:content="brain/Title"
                    >Author Name</span>
                    <span class="authorsearch-card__description"
                          i18n:translate="label_all_reviews_author"
                    >All reviews of this author</span>
                  </span>
                </a>
              </div>

              <button class="authorsearch-batch-loader"
                      type="button"
                      data-authorsearch-loader
                      tal:attributes="
                        data-authorsearch-url panel/next_url | nothing;
                        hidden python:None if (panel['loaded'] and panel['next_url']) else 'hidden';
                      "
              >
                <span i18n:translate="label_publicationlisting_loading">Loading contents&hellip;</span>
              </button>
            </section>
          </tal:panels>
        </div>
      </div>

    </metal:main>

  </body>
</html>
